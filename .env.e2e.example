# ---------------------------------------------------------------------------
# E2E live round-trip secrets (TON Phase 1). Copy to .env.e2e and fill in.
#
#   cp .env.e2e.example .env.e2e   # .env.e2e is gitignored — never commit it
#
# These are the ONLY vars the harness reads (tools/e2e/config.ts → loadE2eConfig).
# The per-service runtime env (.env.example) is built internally by buildRunEnv,
# so you do NOT need to fill that out for `npm run e2e:ton`.
#
# Run locally:   tools/e2e/run-local.sh
# Push to CI:    tools/e2e/set-secrets.sh
#
# DEDICATED LOW-STAKES ACCOUNTS ONLY. Never use a TVL-holding gateway key.
# VIZ runs on mainnet with tiny amounts; TON wVIZ runs on TON testnet.
# Values with spaces (the 24-word mnemonics) MUST stay double-quoted.
# ---------------------------------------------------------------------------

# --- VIZ (mainnet, tiny amounts) -------------------------------------------
E2E_VIZ_NODE_URL=https://node.viz.cx
E2E_VIZ_TEST_WIF=                       # SECRET: WIF active key of the test account that locks VIZ
E2E_VIZ_TEST_ACCOUNT=                   # test account name (locks VIZ on peg-in)
E2E_VIZ_GATEWAY_ACCOUNT=                # the gateway VIZ account name (same as production)
E2E_VIZ_GATEWAY_WIF=                    # SECRET: gateway account's active key (signs peg-out releases)
E2E_VIZ_RECIPIENT=                      # release recipient account name (receives released VIZ)
E2E_VIZ_MIN_BALANCE_MILLI_VIZ=50000     # preflight floor: 50,000 mVIZ = 50 VIZ (1 VIZ = 1000 mVIZ; a round trip costs ~30 VIZ: 20 principal returns + ~10 VIZ fee)

# --- TON (testnet) ---------------------------------------------------------
E2E_TON_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
E2E_TON_API_KEY=                        # SECRET: toncenter testnet API key
E2E_TON_GATEWAY_JETTON_WALLET=          # gateway's wVIZ jetton wallet address
E2E_TON_GATEWAY_OWNER=                  # gateway's owner address (jetton transfer destination)
E2E_TON_JETTON_MINTER_ADDRESS=          # wVIZ jetton minter address
E2E_TON_MULTISIG_ADDRESS=               # deployed multisig-v2 address (admin of the wVIZ minter)
E2E_TON_SIGNER_MNEMONIC=""              # SECRET: 24-word mnemonic of the multisig signer wallet
E2E_TON_BURN_MNEMONIC=""                # SECRET (most sensitive): 24-word burn-wallet mnemonic
E2E_TON_BURN_OWNER=                     # burn wallet address (public; the wVIZ mint recipient)
E2E_TON_MIN_GAS_NANO=100000000          # gas reserve floor: 100,000,000 nanoTON = 0.1 TON
