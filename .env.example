# ---------------------------------------------------------------------------
# Per-operator configuration. Copy to .env and fill in. NEVER commit .env.
# Public, shared values (federation manifest) can be committed; secrets cannot.
# ---------------------------------------------------------------------------

# Which service this container runs: viz-watcher | ton-watcher | signer | coordinator | recon
SERVICE=signer

# This operator's id (must match an entry in the federation manifest)
OPERATOR_ID=op-1

# --- Federation (PUBLIC, shared across all operators) ----------------------
# Preferred: a committed manifest with operator ids + pubkeys (see
# federation.json.example). When present it wins and supplies N/threshold/operators;
# the rotation tool rewrites it after a successful `rotate broadcast viz`.
FEDERATION_MANIFEST=./federation.json
# Fallback when no manifest file exists: count-only synthesis (op-1..op-N, no
# pubkeys). Defaults to 1-of-1 for a solo bootstrap; grow by adding keys + raising
# threshold (or, better, by committing a manifest and rotating).
FEDERATION_N=1
FEDERATION_THRESHOLD=1

# --- VIZ chain -------------------------------------------------------------
# Node URL. Accepts http(s):// or ws(s):// (transport is chosen from the scheme).
VIZ_NODE_URL=https://node.viz.cx
VIZ_GATEWAY_ACCOUNT=viz-gateway
# This operator's VIZ active-authority private key (SECRET). Use a file/secret store in prod.
VIZ_SIGNING_WIF=

# How VIZ irreversibility is treated. The watcher uses last_irreversible_block_num;
# this is an extra safety lag in blocks on top of that.
VIZ_EXTRA_CONFIRMATIONS=2

# --- TON chain -------------------------------------------------------------
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=
TON_MULTISIG_ADDRESS=
TON_JETTON_MINTER_ADDRESS=
TON_GATEWAY_JETTON_WALLET=
# This operator's TON multisig signer key (SECRET, ed25519 mnemonic or hex)
TON_SIGNER_MNEMONIC=
# Masterchain blocks to wait after a burn before treating it final
TON_FINALITY_CONFIRMATIONS=1
TON_MAX_TRANSACTIONS=20           # txs fetched per peg-out scan (RPC rate-limit tuning)

# --- Solana chain (optional; remote chain #2, read path live) --------------
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WVIZ_MINT=                 # Token-2022 wVIZ mint address (after deploy)
SOLANA_GATEWAY_TOKEN_ACCOUNT=     # gateway's wVIZ token account (peg-out deposits)
SOLANA_FINALITY_SLOTS=0           # extra slots beyond 'finalized'
SOLANA_MAX_SIGNATURES=25          # signatures fetched per peg-out scan
SOLANA_RPC_TX_DELAY_MS=250        # delay between per-tx parses (429 avoidance)
SOLANA_SUBMITTER_MIN_LAMPORTS=50000000  # reserve alert floor (~0.05 SOL) for the submitter
# Peg-out Variant A: per-VIZ-account deterministic deposit addresses (no memo on Solana).
SOLANA_DEPOSIT_MASTER_SEED=       # hot seed deriving deposit addresses (generate once, keep safe)
LOOKUP_LISTEN=127.0.0.1:8095      # deposit-address lookup service bind

# --- Coordinator -----------------------------------------------------------
COORDINATOR_URL=http://coordinator:8080
COORDINATOR_LISTEN=0.0.0.0:8080
# Signer /approve endpoints the coordinator calls (comma-separated). Solo: one.
SIGNER_ENDPOINTS=http://signer:8090

# --- Dispatcher (drains the outbox to the coordinator with retries) --------
DISPATCHER_INTERVAL_MS=5000          # loop tick
DISPATCHER_RETRY_INTERVAL_MS=10000   # backoff between attempts (P3: 10s)
DISPATCHER_WINDOW_MS=180000          # deliver window before REFUND (P3: 3 min)

# --- Fees (peg-in only; peg-out + refunds are free) ------------------------
# Fee is HELD IN VIZ; we mint NET (gross - fee). All amounts integer milli-VIZ.
# base = max(floor, bps%); + per-chain activation surcharge when the destination
# address is not provisioned yet (rent the gateway would otherwise eat). These
# MUST be identical across operators (determinism), so mint signatures merge.
FEE_FLOOR_MILLI_VIZ=10000               # 10 VIZ floor
FEE_BPS=20                              # 0.20% (overtakes the floor above ~5,000 VIZ)
FEE_ACTIVATION_SOLANA_MILLI_VIZ=10000   # +10 VIZ if recipient ATA not yet created
FEE_ACTIVATION_TON_MILLI_VIZ=10000      # +10 VIZ if recipient jetton-wallet not deployed
MINT_GAS_FLOOR_SOLANA_MILLI_VIZ=1000    # net must clear this, else refund
MINT_GAS_FLOOR_TON_MILLI_VIZ=1000
# Service VIZ account collecting swept peg-in fees (single-key, no multisig).
FEES_GATE_ACCOUNT=fees.gate

# --- Caps / circuit breakers (conservative bootstrap; raise with TVL) ------
# Amounts in integer milli-VIZ (1 VIZ = 1000 milli-VIZ).
CAP_PER_TX_MILLI_VIZ=200000000          # 200,000 VIZ (~$1,000)
CAP_24H_MILLI_VIZ=2000000000            # 2,000,000 VIZ (~$10,000)
# Transfers above this require manual multi-operator review before signing
MANUAL_REVIEW_ABOVE_MILLI_VIZ=100000000 # 100,000 VIZ (~$500)

# --- Storage ---------------------------------------------------------------
# Idempotency / pending-order ledger. sqlite path for dev; postgres URL for prod.
STORE_URL=sqlite:./data/gateway.sqlite

# --- Reconciliation --------------------------------------------------------
RECON_INTERVAL_MS=30000
# Tolerated drift in milli-VIZ before auto-pause (dust)
RECON_DRIFT_TOLERANCE_MILLI_VIZ=0
