              {
                "kind": "arg",
                "path": "viz_account"
              }
            ]
          }
        },
        {
          "name": "mint",
          "writable": true
        },
        {
          "name": "deposit_ata",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "account",
