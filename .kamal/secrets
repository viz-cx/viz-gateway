# shellcheck shell=bash
# shellcheck disable=SC2034  # Vars are consumed by Kamal externally.
#
# Kamal reads this with dotenv (NOT bash): plain assignment + $(...) work, but bash
# default-expansion ${VAR:-default} does not. Shared by BOTH apps in this repo
# (deploy.coordinator.yml + deploy.signer.yml), so ALL THREE SOPS sources below must exist
# before EITHER `kamal deploy` — Kamal evaluates the whole file regardless of which app it
# is deploying, and a `sops -d` on a missing file aborts the deploy.
#
# Secrets are pulled from the sibling private infra repo's SOPS files (two levels up:
# .../Develop/VIZ/viz-gateway → .../Develop/infra). Nothing secret is written to disk.
INFRA=../../infra

# GHCR pull/push PAT (write:packages). Shared across every axveer app.
KAMAL_REGISTRY_PASSWORD=$(sops -d --extract '["docker_registry_password"]' "$INFRA/secrets/shared.enc.yaml")

# toncenter API key — single-sourced from the coordinator app's SOPS file and reused by the
# signer app (both env.secret blocks reference GRAM_API_KEY).
GRAM_API_KEY=$(sops -d --extract '["gram_api_key"]' "$INFRA/secrets/apps/viz-gateway-coordinator.enc.yaml")

# Passphrase that unseals op-1's keystore.mainnet.json at signer boot. Only the signer app
# references it; it is still extracted on a coordinator deploy (see header) — harmless.
# SOPS key is fed_keystore_passWORD (not …passphrase) so it matches .sops.yaml's
# encrypted_regex (…_password) and is actually encrypted at rest; the Kamal env var it
# feeds is still FED_KEYSTORE_PASSPHRASE (what config.ts reads).
FED_KEYSTORE_PASSPHRASE=$(sops -d --extract '["fed_keystore_password"]' "$INFRA/secrets/apps/viz-gateway-signer.enc.yaml")
