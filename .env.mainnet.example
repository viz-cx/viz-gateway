# ============================================================================
# viz-gateway — MAINNET RUNTIME template (2-of-3, TON-only launch)
# ----------------------------------------------------------------------------
# Copy to .env.mainnet and fill the SECRET placeholders. Public values below are
# already the live mainnet addresses and are IDENTICAL on every operator's box.
# NEVER commit a filled .env.mainnet (it is gitignored); this *.example is safe.
#
# Topology (docs/runbook-mainnet-bringup.md):
#   - ONE coordinator box: viz-watcher + gram-watcher + coordinator + dispatcher
#     + recon  (keyless on TON — proposes/approves via the operators' signers)
#   - ONE signer daemon PER operator: own keystore + own independent RPC (F2)
# Run each process with its own SERVICE, e.g.  SERVICE=signer npm run start:signer
# ============================================================================

# Which process THIS invocation runs: viz-watcher|gram-watcher|signer|coordinator|recon
SERVICE=signer
# This operator's id is DERIVED from the VIZ signing key (looked up in federation.json) —
# leave unset. Set it only to assert an expected slot: a wrong value warns and is overridden.
# OPERATOR_ID=op-1

# --- Federation (PUBLIC; committed manifest supplies n/threshold/operators) --
FEDERATION_MANIFEST=./federation.json

# --- Key custody (SECRET — seal into a keystore; never commit/share) ---------
#   node tools/keystore.cjs seal ./keystore.mainnet.json   (reads VIZ_SIGNING_WIF
#     + GRAM_SIGNER_MNEMONIC from env, then UNSET the plaintext vars)
FED_KEYSTORE=
FED_KEYSTORE_PASSPHRASE=

# --- VIZ chain (home: lock/release) -----------------------------------------
# F2 INVARIANT: point this at YOUR OWN VIZ node, never a coordinator-fed endpoint.
VIZ_NODE_URL=https://node.viz.cx
VIZ_GATEWAY_ACCOUNT_GRAM=gram.gate
VIZ_GATEWAY_ACCOUNT_SOLANA=solana.gate
FEES_GATE_ACCOUNT=fees.gate
# This operator's VIZ active-authority WIF (SECRET; one of the gram.gate 2-of-3).
VIZ_SIGNING_WIF=

# --- GRAM (TON) chain — PUBLIC mainnet addresses (do not change) -------------
GRAM_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
GRAM_API_KEY=
GRAM_JETTON_MINTER_ADDRESS=EQAHujyCaWPjfNaAKHSPDlJZJd2mhWl203eLWShz8PM3_VIZ
GRAM_MULTISIG_ADDRESS=EQCfGcOZtfv7RgUuT0vddjFEinDIiAdZagyj70CvmqqLZ9m0
GRAM_GATEWAY_JETTON_WALLET=EQCjDw0JMwpzK-cQInWKABBspYWi-jP9PQgkQsqZ21UgsPhy
# This operator's TON multisig signer wallet mnemonic (SECRET, 24 words).
GRAM_SIGNER_MNEMONIC=

# --- Coordinator <-> signers ------------------------------------------------
# SIGNER box: bind /approve so the coordinator on another host can reach it. The
# code default is 127.0.0.1:8101 (localhost-only) — unreachable cross-box — so this
# MUST be set to a routable bind on a signer box. Put it behind mTLS/VPN. Port 8101
# (not 8090) leaves a co-located viz-cpp-node's 8090-8093 RPC ports free.
SIGNER_LISTEN=0.0.0.0:8101
# The coordinator discovers signers by authenticated self-registration (each signer POSTs
# its SIGNER_ADVERTISE_URL) — there is no SIGNER_ENDPOINTS list to maintain.
COORDINATOR_URL=http://coordinator-host:8100
COORDINATOR_LISTEN=0.0.0.0:8100

# --- Caps: UNLIMITED at launch (Phase 0 decision, risk accepted) ------------
# Effectively-infinite milli-VIZ; disables the per-tx/24h ceilings + OVER_24H
# auto-pause. Tighten (see .env.example) as TVL/federation grow.
CAP_PER_TX_MILLI_VIZ=1000000000000000000000000000000
CAP_24H_MILLI_VIZ=1000000000000000000000000000000
MANUAL_REVIEW_ABOVE_MILLI_VIZ=1000000000000000000000000000000

# --- Reconciliation: TON-only launch (GRAM must be monitored) ---------------
RECON_EXPECTED_REMOTES=GRAM

# --- Storage ----------------------------------------------------------------
STORE_URL=sqlite:./data/gateway.sqlite

# --- Operator alerting (a prod custody bridge MUST set this) -----------------
STAFF_WEBHOOK_URL=
